# TWILIO
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX        # Your Twilio outbound number

# OPENAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o                     # or gpt-4o-mini for lower cost

# ELEVENLABS
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Default: Rachel — replace with your cloned voice

# SARVAM (Indian languages — Hindi, Marathi, etc.)
SARVAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# REDIS (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# SERVER
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
PUBLIC_URL=https://yourdomain.com       # Your public server URL (for Twilio webhooks)

# APP
COMPANY_NAME=MuTech Automation
