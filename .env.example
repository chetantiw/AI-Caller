################################################################################
# PIOPIY Configuration - REQUIRED for outbound calls
################################################################################

# PIOPIY Dashboard credentials (https://dashboard.piopiy.com/)
AGENT_ID=your_agent_id_here
AGENT_TOKEN=your_agent_token_here
PIOPIY_TOKEN=your_rest_api_token_here

# Phone number purchased and assigned in PIOPIY Dashboard
# Format: +91 for India, or country code as needed
PIOPIY_NUMBER=+919876543210

################################################################################
# AI Service Credentials (Recommended Stack)
################################################################################

# Speech-to-Text (Deepgram - preferred for low latency)
# Free account: https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Language Model (OpenAI - preferred for quality)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Text-to-Speech (Cartesia - preferred for natural voice)
# Free trial: https://play.cartesia.ai/console
CARTESIA_API_KEY=

################################################################################
# Alt AI Services (optional - only if not using defaults above)
################################################################################

# Groq LLM - fast inference, free tier available
GROQ_API_KEY=

# Sarvam AI - excellent Hindi support for both STT and TTS
SARVAM_API_KEY=

################################################################################
# Application Configuration
################################################################################

# Public URL for callbacks
PUBLIC_URL=https://ai.mutechautomation.com

# Environment mode
ENVIRONMENT=development

# Safety switch for local stabilization tests.
# true = API/campaign flows return fake call IDs without dialing PIOPIY/Exotel.
AI_CALLER_DRY_RUN=false

# JWT/Auth Secret
JWT_SECRET=mutech-secret-2026

# Database (if using SQLite)
DATABASE_URL=sqlite:///./calls.db

# Exotel Configuration (if using Exotel as fallback)
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_ACCOUNT_SID=mutechautomation1
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_VIRTUAL_NUMBER=07314854688

################################################################################
# Follow-up Automation (Optional)
################################################################################

# WhatsApp via teleCMI/PIOPIY
# Use your existing PIOPIY credentials plus WhatsApp number
PIOPIY_WHATSAPP_NUMBER=+919876543210  # Your WhatsApp-enabled number from teleCMI

# Email Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_SMTP=smtp.gmail.com

################################################################################
# Notes
################################################################################

# REQUIRED: At minimum, you need:
# - AGENT_ID, AGENT_TOKEN, PIOPIY_TOKEN, PIOPIY_NUMBER (for PIOPIY)
# - One STT provider (DEEPGRAM_API_KEY or SARVAM_API_KEY)
# - One LLM provider (OPENAI_API_KEY or GROQ_API_KEY)
# - One TTS provider (CARTESIA_API_KEY or SARVAM_API_KEY)

# For testing: You can get free tier API keys from most providers
# For production: Monitor usage and upgrade as needed
