# ─────────────────────────────────────────────────────────────
#  AI Cold Calling Agent — Environment Config
#  Stack: PIOPIY/TeleCMI + Sarvam AI (STT+TTS) + OpenAI GPT-4o
# ─────────────────────────────────────────────────────────────

# ── PIOPIY (TeleCMI) ──────────────────────────────────────────
# Get from: https://developer.telecmi.com → Your App → App ID & Secret
PIOPIY_APP_ID=2222226
PIOPIY_APP_SECRET=xxxx-xxxx-xxxx-xxxx
PIOPIY_PHONE_NUMBER=91XXXXXXXXXX       # Your PIOPIY number WITHOUT + prefix

# ── OPENAI ────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# ── SARVAM AI — STT + TTS ─────────────────────────────────────
# Get from: https://dashboard.sarvam.ai
SARVAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SARVAM_STT_MODEL=saarika:v2
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_VOICE=anushka

# ── REDIS ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── SERVER ────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
PUBLIC_URL=https://ai.mutechautomation.com   # Must be publicly accessible for PIOPIY

# ── APP ───────────────────────────────────────────────────────
COMPANY_NAME=MuTech Automation
AGENT_NAME=Priya
LANGUAGE=en
LOG_LEVEL=INFO
