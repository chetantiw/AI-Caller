# ─────────────────────────────────────────────────────────────
#  AI Cold Calling Agent
#  Stack: PIOPIY + Sarvam STT + OpenRouter LLM (Free) + Sarvam TTS
# ─────────────────────────────────────────────────────────────

# ── PIOPIY (TeleCMI) ──────────────────────────────────────────
# Get from: https://developer.telecmi.com → Your App
PIOPIY_APP_ID=2222226
PIOPIY_APP_SECRET=xxxx-xxxx-xxxx-xxxx
PIOPIY_PHONE_NUMBER=91XXXXXXXXXX           # NO + prefix

# ── OPENROUTER — LLM ──────────────────────────────────────────
# Get API key: https://openrouter.ai/settings/keys
# Free tier: 50 req/day | $10 deposit → 1000 req/day
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── FREE MODEL OPTIONS (uncomment one) ────────────────────────
# Best quality + Hindi support (RECOMMENDED)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Fastest free model (use if Llama is too slow)
# OPENROUTER_MODEL=stepfun/step-3.5-flash:free

# Ultra fast, lower quality
# OPENROUTER_MODEL=arcee-ai/trinity-mini:free

# ── SARVAM AI — STT + TTS (Single Key) ────────────────────────
# Get from: https://dashboard.sarvam.ai
SARVAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SARVAM_STT_MODEL=saarika:v2
SARVAM_TTS_MODEL=bulbul:v2

# ── REDIS ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── SERVER ────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
PUBLIC_URL=https://ai.mutechautomation.com

# ── APP ───────────────────────────────────────────────────────
COMPANY_NAME=MuTech Automation
AGENT_NAME=Priya
LANGUAGE=en
LOG_LEVEL=INFO
